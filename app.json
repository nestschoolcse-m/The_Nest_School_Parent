{
  "expo": {
    "name": "NEST ERP Parent",
    "slug": "nest-erp-parent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/thenestschoollogo.png",
    "scheme": "nest-erp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nest.erp.parent"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e40af"
      },
      "package": "com.nest.erp.parent"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#1e40af"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "edc79d6d-852b-419f-bde0-73eac23df12a"
      }
    },
    "owner": "lakshwin.kr"
  }
}
